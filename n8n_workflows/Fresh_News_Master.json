        "responses": {
          "values": [
            {
              "role": "system",
              "content": "Você é o Editor-Chefe da Fresh News.\nO artigo recebido pertence ao mundo: {{ $('Loop Fontes').item.json.world }}.\n\nDIRETRIZES GERAIS:\nEscreva um resumo denso, direto e sem hype. Fale de especialista para especialista. Em pt-BR.\n\nMUNDOS E SUBCATEGORIAS:\n- TECH: SEC, IA, DEV, CLOUD\n- GAME: PC, CONSOLE, ESPORTS, INDIE\n- MUSIC: ARTISTAS, PRODUCAO, INDIE, LANCAMENTOS\n- GEAR: GADGETS, HARDWARE, AUTOMOTIVO, DIY\n\nCONTRATO DE SAÍDA (Apenas JSON válido):\n{\n  \"title\": \"Manchete forte em pt-BR (Máx 60 chars)\",\n  \"summary\": \"Micro-reportagem técnica. (300 a 400 chars)\",\n  \"whatsapp_summary\": \"🔥 [Manchete Curta]. [Veredicto]. (Máx 160 chars)\",\n  \"relevance_score\": [0 a 100],\n  \"category\": \"Preencha com o nome da categoria macro (ex: TECH_HACKER, GAME_BUILDER, MUSIC_MAKER, GEAR_SETUP)\",\n  \"sub_category\": \"Escolha a subcategoria exata da lista acima que melhor encaixa no texto\",\n  \"theme_config\": {\n    \"dna\": \"Preencha com o DNA (TECH_HACKER, GAME_GOLD, SYNTHWAVE_PURPLE, GEAR_RED)\",\n    \"primary_color\": \"#0D0D0D\",\n    \"accent_color\": \"#00FF41\",\n    \"font_style\": \"Mono\",\n    \"ui_effects\": [\"scanlines\"]\n  }\n}"
            },
            {
              "content": "={{ $json.data.markdown }}"
            }
          ]
        }
      },
      "credentials": {
        "postgres": {
          "id": "pP8yWr9x5fTmLR7m",
          "name": "Postgres account 2"
        },
        "openAiApi": {
          "id": "wcWQeHLQ90vJVbyG",
          "name": "OpenAi account"
        }
      }
    },
    {
      "id": "a1ebdd45-bb29-48fb-af32-08d691f0e0be",
      "name": "Limpar JSON Ingestão",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1800,
        0
      ],
      "parameters": {
        "jsCode": "\nconst aiText = $json.content || \"{}\";\nlet parsed = {};\ntry {\n  parsed = JSON.parse(aiText.replace(/```json/g, \"\").replace(/```/g, \"\").trim());\n} catch(e) {}\n\nreturn {\n  title: parsed.title || \"Sem título\",\n  summary: parsed.summary || \"\",\n  whatsapp_summary: parsed.whatsapp_summary || \"\",\n  score: parsed.relevance_score || 0,\n  category: parsed.category || \"TECH_HACKER\",\n  sub_category: parsed.sub_category || \"DEV\",\n  theme_config: parsed.theme_config || {},\n  world: $('Loop Fontes').item.json.world,\n  url: $('Loop Notícias').item.json.link,\n  content: $('API: Firecrawl').item.json.data.markdown\n};\n"
      },
      "credentials": {}
