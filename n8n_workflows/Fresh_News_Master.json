      "parameters": {
        "jsCode": "\nconst posts = $json.posts;\nconst titles = posts.map(p => p.title).join('\\n- ');\nconst contentStr = posts.map(p => `TÍTULO: ${p.title}\\nRESUMO: ${p.summary}`).join('\\n\\n');\n\nreturn {\n  world: $('Loop Mundos').item.json.world,\n  post_ids: posts.map(p => p.id),\n  titles_list: titles,\n  content_to_read: contentStr\n};\n"
      },
