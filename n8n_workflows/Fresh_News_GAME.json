        "responses": {
          "values": [
            {
              "role": "system",
              "content": "Você é o Editor-Chefe de Triagem da Fresh News (Mundo GAME).\nSua única missão é classificar o artigo fornecido na subcategoria correta.\n\nDIRETRIZES DE CLASSIFICAÇÃO:\n- PC: Foco em pc\n- CONSOLE: Foco em console\n- ESPORTS: Foco em esports\n- INDIE: Foco em indie\n\nCONTRATO DE SAÍDA (Retorne APENAS o objeto JSON abaixo):\n{\n  \"category\": \"GAME_BUILDER\",\n  \"sub_category\": \"PC\" | \"CONSOLE\" | \"ESPORTS\" | \"INDIE\",\n  \"routing_reason\": \"Justificativa direta em 1 frase em pt-BR.\"\n}"
            },
            {
              "content": "={{ $json.texto_markdown }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        352,
        0
      ],
      "id": "9363caf8-8f7d-4625-b474-4506ca9f335c",
      "name": "IA: Editor-Chefe GAME",
      "credentials": {
        "openAiApi": {
          "id": "wcWQeHLQ90vJVbyG",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map((item) => {\n  const data = item.json;\n  \n  try {\n    const rawText = data.output?.[0]?.content?.[0]?.text || \"{}\";\n    const parsed = JSON.parse(rawText);\n\n    return {\n      ...data,\n      category: parsed.category || \"GAME_BUILDER\",\n      sub_category: parsed.sub_category || \"SEM_SUBCATEGORIA\"\n    };\n    \n  } catch (err) {\n    return {\n      ...data,\n      category: \"GAME_BUILDER\",\n      sub_category: \"ERRO_JSON\",\n      error_details: String(err)\n    };\n  }\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        -16
      ],
      "id": "71ec2650-7cec-4c6c-9617-0fe4817fcf26",
      "name": "Code in JavaScript2"
    },
