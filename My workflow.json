    {
      "parameters": {
        "jsCode": "// Usamos 'any' para desativar as restrições chatas de tipo do TypeScript\nreturn $input.all().map((item) => {\n  const data = item.json;\n  \n  try {\n    // 1. Localiza o texto dentro da estrutura complexa da IA\n    // Usamos o ?. para evitar erro se o caminho não existir\n    const rawText = data.output?.[0]?.content?.[0]?.text || \"{}\";\n\n    // 2. Converte o texto para objeto JSON\n    const parsed = JSON.parse(rawText);\n\n    // 3. Retorna TUDO o que já existia + os novos campos limpos\n    return {\n      ...data,\n      category: parsed.category || \"SEM_CATEGORIA\",\n      sub_category: parsed.sub_category || \"SEM_SUBCATEGORIA\"\n    };\n    \n  } catch (err) {\n    // Se der erro no parse, ele não trava o fluxo\n    return {\n      ...data,\n      category: \"ERRO_JSON\",\n      sub_category: \"ERRO_JSON\",\n      error_details: String(err)\n    };\n  }\n});"
      },
      "type": "n8n-nodes-base.code",
